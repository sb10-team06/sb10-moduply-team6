# .env 파일 예시
SPRING_PROFILES_ACTIVE=local

POSTGRES_USER_NAME=admin
POSTGRES_PASSWORD=0000
POSTGRES_DB=moduply

AWS_S3_ACCESS_KEY= 엑세스키
AWS_S3_SECRET_KEY= 시크릿키
AWS_S3_REGION= 리전
AWS_S3_BUCKET= 버킷명
AWS_S3_PRESIGNED_URL_EXPIRATION=600

# 외부 콘텐츠 API 설정
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
TMDB_READ_ACCESS_TOKEN=발급받은_TMDB_읽기_토큰
TMDB_CONNECT_TIMEOUT_MILLIS=3000
TMDB_READ_TIMEOUT_MILLIS=10000

SPORTS_DB_BASE_URL=https://www.thesportsdb.com/api/v1/json
SPORTS_DB_API_KEY=발급받은_SPORTS_DB_API_KEY
SPORTS_DB_CONNECT_TIMEOUT_MILLIS=3000
SPORTS_DB_READ_TIMEOUT_MILLIS=10000

# TMDB Discover 영화 수집 조건
# 기본값은 한국 기준 15세 이하, 투표 수 10개 이상, 최신 개봉일순 수집입니다.
# WITHOUT_KEYWORDS, WITHOUT_GENRES는 TMDB id를 | 또는 ,로 구분해 입력할 수 있습니다.
TMDB_MOVIE_INCLUDE_ADULT=false
TMDB_MOVIE_INCLUDE_VIDEO=false
TMDB_MOVIE_SORT_BY=primary_release_date.desc
TMDB_MOVIE_REGION=KR
TMDB_MOVIE_CERTIFICATION_COUNTRY=KR
TMDB_MOVIE_CERTIFICATION_LTE=15
TMDB_MOVIE_VOTE_COUNT_GTE=10
TMDB_MOVIE_WITHOUT_KEYWORDS=
TMDB_MOVIE_WITHOUT_GENRES=

# TMDB Discover TV 수집 조건
# 기본값은 adult 콘텐츠 제외, 투표 수 10개 이상, 최신 첫 방영일순 수집입니다.
# TV Discover API는 영화처럼 한국 등급 조건을 직접 적용하기 어려워 keyword/genre 제외값으로 보강합니다.
TMDB_TV_INCLUDE_ADULT=false
TMDB_TV_SORT_BY=first_air_date.desc
TMDB_TV_VOTE_COUNT_GTE=10
TMDB_TV_WITHOUT_KEYWORDS=
TMDB_TV_WITHOUT_GENRES=

# 외부 이미지 다운로드 설정
EXTERNAL_IMAGE_CONNECT_TIMEOUT_MILLIS=3000
EXTERNAL_IMAGE_READ_TIMEOUT_MILLIS=10000

# 콘텐츠 수집 Batch 설정
# 기본값은 매일 새벽 2시에 TMDB 1~3페이지와 Sports DB 기본 리그/날짜 범위를 수집합니다.
CONTENT_IMPORT_BATCH_ENABLED=true
CONTENT_IMPORT_BATCH_CRON="0 0 2 * * *"
CONTENT_IMPORT_BATCH_TMDB_PAGE_START=1
CONTENT_IMPORT_BATCH_TMDB_PAGE_END=3
CONTENT_IMPORT_BATCH_TMDB_LANGUAGE=ko-KR
CONTENT_IMPORT_BATCH_SPORTS_DB_LEAGUE_IDS=4328
CONTENT_IMPORT_BATCH_SPORTS_DB_SPORT=Soccer
CONTENT_IMPORT_BATCH_SPORTS_DB_DAY_OFFSET_PREVIOUS=-1
CONTENT_IMPORT_BATCH_SPORTS_DB_DAY_OFFSET_TODAY=0
CONTENT_IMPORT_BATCH_SPORTS_DB_DAY_OFFSET_NEXT=1

#k6용
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=admin1234

#동기(false)/비동기(true) 설정
MODUPLY_BINARY_CONTENT_ASYNC_ENABLED=true
